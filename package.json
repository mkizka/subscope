{
  "name": "@repo/workspace",
  "version": "1.0.0",
  "packageManager": "pnpm@11.5.0+sha512.dbfcc4f81cf48597afd4bc391ffdf12c11f1a9fb83a395bfa6b0a2d9cc2fd8ffebafdb1ccbd529632153f793904c2615b7f09fe1a345473fd1c35845172a8eb1",
  "engines": {
    "node": "24"
  },
  "scripts": {
    "_prettier": "prettier --ignore-path .prettier --ignore-path .gitignore",
    "all": "turbo run typecheck format && vitest run",
    "all:unit": "turbo run typecheck format && pnpm test:unit run",
    "build": "turbo run build",
    "db:generate": "pnpm --filter @repo/db db:generate",
    "db:migrate": "pnpm --filter @repo/db db:migrate",
    "dev": "./scripts/dev.sh",
    "format": "pnpm -s _prettier . --write && turbo run format",
    "get-docs": "./scripts/get-docs.sh",
    "lint": "pnpm -s _prettier . --check && turbo run lint",
    "prepare": "husky",
    "storybook": "pnpm --filter @repo/web storybook",
    "studio": "pnpm --filter @repo/db dev",
    "test": "vitest",
    "test:unit": "vitest --project *:unit",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.7",
    "husky": "9.1.7",
    "kill-port": "2.0.1",
    "lint-staged": "17.0.5",
    "prettier": "3.8.3",
    "prettier-plugin-pkg": "0.22.1",
    "prettier-plugin-sh": "0.18.1",
    "repomix": "1.14.1",
    "turbo": "2.9.16",
    "vitest": "4.1.7",
    "wait-on": "9.0.10"
  },
  "lint-staged": {
    "*": "pnpm -s _prettier --ignore-unknown --write"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-pkg",
      "prettier-plugin-sh"
    ]
  }
}
